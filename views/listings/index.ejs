<% layout("layouts/boilerplate") %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --ink: #1a1a1a;
      --ink-soft: #444;
      --ink-muted: #888;
      --surface: #f7f5f2;
      --white: #ffffff;
      --border: #e6e2db;
      --red: #e8334a;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.07);
      --shadow-md: 0 6px 24px rgba(0, 0, 0, 0.10);
      --tr: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      --skel-base: #e8e4df;
      --skel-shine: #f5f2ee;
    }

    body {
      background: var(--surface);
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--ink);
    }

    a { text-decoration: none; color: inherit; }

    .banner-strip {
      border-radius: 12px;
      padding: 0.7rem 1.1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      font-size: 0.86rem;
      font-weight: 500;
      margin-top: 1rem;
      border: 1px solid transparent;
      flex-wrap: wrap;  
    }

    .banner-strip.search-banner {
      background: #edf6ff;
      border-color: #c5dff7;
      color: #1a5fa0;
    }

    .banner-strip.filter-banner {
      background: #edf7f0;
      border-color: #b8e0c5;
      color: #1e6640;
    }

    .banner-clear {
      padding: 0.28rem 0.85rem;
      border-radius: 100px;
      font-size: 0.76rem;
      font-weight: 700;
      border: 1.5px solid currentColor;
      opacity: 0.7;
      transition: opacity 0.2s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .banner-clear:hover { opacity: 1; }

    .filter-bar-wrap { margin-top: 1rem; }

    .filters-main-container {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--white);
      border-radius: 100px;
      padding: 0.45rem 0.6rem;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
    }

    .filters-scroll-area {
      flex: 1;
      overflow: hidden;
      position: relative;
      min-width: 0;  
    }

    #filters {
      display: flex;
      gap: 0.1rem;
      align-items: center;
      white-space: nowrap;
    }

    .filter-link { display: inline-block; }

    .filter {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      padding: 0.42rem 0.85rem 0.48rem;
      border-radius: 100px;
      cursor: pointer;
      transition: var(--tr);
      border: 1.5px solid transparent;
      background: transparent;
      min-width: 72px;
    }

    .filter i {
      font-size: 1.18rem;
      color: #888;
      transition: color 0.2s, transform 0.22s;
    }

    .filter p {
      font-size: 0.71rem;
      font-weight: 600;
      color: #888;
      margin: 0.2rem 0 0;
      transition: color 0.2s;
      letter-spacing: 0.01em;
    }

    .filter:hover { background: #f5f3ef; }
    .filter:hover i, .filter:hover p { color: var(--ink); }
    .filter:hover i { transform: translateY(-2px); }

    .filter.active-filter {
      background: var(--ink);
      border-color: var(--ink);
    }

    .filter.active-filter i,
    .filter.active-filter p { color: var(--white) !important; }

    .see-more-btn {
      flex-shrink: 0;
      background: transparent;
      border: 1.5px solid var(--border);
      border-radius: 100px;
      padding: 0.42rem 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      white-space: nowrap;
      transition: var(--tr);
      color: var(--ink-soft);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.76rem;
      font-weight: 700;
    }

    .see-more-btn:hover {
      background: var(--ink);
      border-color: var(--ink);
      color: white;
    }

    .see-more-btn i { font-size: 0.68rem; }

    .tax-toggel {
      flex-shrink: 0;
      border: 1.5px solid var(--border);
      padding: 0.42rem 0.95rem;
      border-radius: 100px;
      display: flex;
      align-items: center;
      background: transparent;
      transition: var(--tr);
      gap: 0.45rem;
      cursor: pointer;
    }

    .tax-toggel:hover { border-color: var(--ink); }

    .tax-toggel .form-check-label {
      font-size: 0.76rem;
      font-weight: 600;
      cursor: pointer;
      color: var(--ink-soft);
      white-space: nowrap;
    }

    .form-check-input:checked {
      background-color: var(--ink) !important;
      border-color: var(--ink) !important;
    }

    @media (min-width: 1037px) {
      .filters-scroll-area { overflow: hidden; }

      #filters {
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(0);
      }

      #filters.show-extra { transform: translateX(-480px); }
    }

    @media (max-width: 1036px) {
      .see-more-btn { display: none !important; }
    }

    @media (min-width: 768px) and (max-width: 1036px) {
      .filters-scroll-area {
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      .filters-scroll-area::-webkit-scrollbar { display: none; }
      #filters { transform: none !important; }
    }

    @media (max-width: 767px) {
      .filters-main-container {
        flex-direction: column;
        align-items: stretch;
        border-radius: 20px;
        padding: 0.5rem 0.5rem 0.6rem;
        gap: 0.4rem;
      }

      .filters-scroll-area {
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
        width: 100%;
      }
      .filters-scroll-area::-webkit-scrollbar { display: none; }

      #filters {
        transform: none !important;
        gap: 0.25rem;
        padding: 0.1rem 0.2rem;
      }

      .filter {
        min-width: 56px;
        padding: 0.45rem 0.7rem 0.5rem;
        flex-shrink: 0;
      }

      .filter i { font-size: 1.1rem; }

      .filter p {
        font-size: 0.65rem;
        margin-top: 0.18rem;
      }

      .tax-toggel {
        width: 100%;
        justify-content: center;
        border-radius: 12px;
        padding: 0.5rem 1rem;
        border-color: var(--border);
      }

      .tax-toggel .form-check-label { font-size: 0.78rem; }
    }

    .listings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
      gap: 2rem 1.75rem;
      margin-top: 2rem;
      padding-bottom: 4rem;
    }

    .listing-item {
      opacity: 0;
      transform: translateY(18px);
      animation: fadeUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    .listing-item:nth-child(1)  { animation-delay: 0.04s; }
    .listing-item:nth-child(2)  { animation-delay: 0.09s; }
    .listing-item:nth-child(3)  { animation-delay: 0.14s; }
    .listing-item:nth-child(4)  { animation-delay: 0.19s; }
    .listing-item:nth-child(5)  { animation-delay: 0.24s; }
    .listing-item:nth-child(6)  { animation-delay: 0.29s; }
    .listing-item:nth-child(n+7){ animation-delay: 0.34s; }

    .card-img-wrap {
      position: relative;
      border-radius: 18px;
      overflow: hidden;
      aspect-ratio: 4 / 3;
      background: #e8e4df;
      margin-bottom: 0.75rem;
    }

    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .card-img-wrap:hover img { transform: scale(1.06); }

    .card-badge {
      position: absolute;
      top: 0.75rem;
      left: 0.75rem;
      background: rgba(255, 255, 255, 0.88);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 100px;
      padding: 0.22rem 0.7rem;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink);
      pointer-events: none;
    }

    .card-fav-btn {
      position: absolute;
      top: 0.72rem;
      right: 0.72rem;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: var(--tr);
      z-index: 10;
      box-shadow: 0 1px 6px rgba(0, 0, 0, 0.14);
    }

    .card-fav-btn:hover {
      transform: scale(1.12);
      background: white;
      box-shadow: 0 3px 12px rgba(0, 0, 0, 0.18);
    }

    .card-fav-btn svg {
      width: 16px;
      height: 16px;
      stroke: #777;
      fill: none;
      stroke-width: 2;
      transition: stroke 0.2s, fill 0.2s;
      pointer-events: none;
    }

    .card-fav-btn.is-fav svg { stroke: var(--red); fill: var(--red); }

    @keyframes heartPop {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.4); }
      70%  { transform: scale(0.88); }
      100% { transform: scale(1); }
    }

    .card-fav-btn.pop { animation: heartPop 0.36s ease; }

    .card-body { padding: 0; }

    .card-top-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.5rem;
      margin-bottom: 0.2rem;
    }

    .card-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.93rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      flex: 1;
    }

    .card-location {
      font-size: 0.78rem;
      color: var(--ink-muted);
      font-weight: 400;
      margin: 0 0 0.5rem;
    }

    .price-line {
      display: flex;
      align-items: baseline;
      gap: 0.28rem;
    }

    .price-amount {
      font-family: 'Nunito', sans-serif;
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.02em;
    }

    .price-label {
      font-size: 0.79rem;
      color: var(--ink-muted);
      font-weight: 400;
    }

    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 5rem 2rem;
    }

    .empty-icon {
      width: 64px;
      height: 64px;
      background: var(--border);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.25rem;
    }

    .empty-icon i { font-size: 1.5rem; color: var(--ink-muted); }

    .empty-state h4 {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
    }

    .empty-state p {
      color: var(--ink-muted);
      font-size: 0.88rem;
      margin-bottom: 1.25rem;
    }

    .btn-dark-pill {
      background: var(--ink);
      color: white;
      padding: 0.6rem 1.8rem;
      border-radius: 100px;
      font-size: 0.86rem;
      font-weight: 700;
      transition: var(--tr);
      display: inline-block;
    }

    .btn-dark-pill:hover {
      background: #333;
      color: white;
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }

    @media (max-width: 767px) {
      .listings-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-top: 1.25rem;
      }

      .card-fav-btn {
        width: 36px;
        height: 36px;
        top: 0.6rem;
        right: 0.6rem;
      }

      .card-fav-btn svg {
        width: 15px;
        height: 15px;
      }

      .card-badge {
        font-size: 0.6rem;
        padding: 0.18rem 0.55rem;
        top: 0.6rem;
        left: 0.6rem;
      }

      .card-title {
        font-size: 0.84rem;
        line-height: 1.25;
      }

      .card-location {
        font-size: 0.72rem;
        margin-bottom: 0.35rem;
        white-space: normal;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .price-amount { font-size: 0.94rem; }
      .price-label  { font-size: 0.72rem; }

      .empty-state { padding: 3rem 1.25rem; }
      .empty-state h4 { font-size: 1.15rem; }
    }

    @keyframes shimmer {
      0%   { background-position: -600px 0; }
      100% { background-position:  600px 0; }
    }

    .skel-block {
      background: linear-gradient(90deg, var(--skel-base) 25%, var(--skel-shine) 50%, var(--skel-base) 75%);
      background-size: 600px 100%;
      animation: shimmer 1.6s infinite linear;
      border-radius: 6px;
    }

    .skeleton-item .skel-img {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 18px;
      margin-bottom: 0.75rem;
      display: block;
    }

    .skeleton-item .skel-title {
      height: 14px;
      width: 65%;
      margin-bottom: 0.45rem;
      display: block;
    }

    .skeleton-item .skel-location {
      height: 11px;
      width: 45%;
      margin-bottom: 0.6rem;
      display: block;
    }

    .skeleton-item .skel-price {
      height: 16px;
      width: 38%;
      display: block;
    }

    #listings-skeleton {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
      gap: 2rem 1.75rem;
      margin-top: 2rem;
      padding-bottom: 4rem;
    }

    @media (max-width: 767px) {
      #listings-skeleton {
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-top: 1.25rem;
      }

      .skeleton-item .skel-img { border-radius: 14px; }
    }

    .listings-grid { display: none; }
  </style>

  <% if (typeof isSearch !== 'undefined' && isSearch && searchTerm) { %>
    <div class="container">
      <div class="banner-strip search-banner">
        <span>
          <i class="fa-solid fa-magnifying-glass" style="margin-right:.4rem"></i>
          Results for <strong>"<%= searchTerm %>"</strong>
        </span>
        <a href="/listings" class="banner-clear">
          <i class="fa-solid fa-times" style="margin-right:.3rem"></i>Clear
        </a>
      </div>
    </div>
  <% } %>

  <div class="container filter-bar-wrap">
    <div class="filters-main-container">

      <div class="filters-scroll-area">
        <div id="filters">

          <a href="/listings/category/trending" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='trending'?'active-filter':'' %>">
              <i class="fa-solid fa-fire"></i><p>Trending</p>
            </div>
          </a>

          <a href="/listings/category/rooms" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='rooms'?'active-filter':'' %>">
              <i class="fa-solid fa-bed"></i><p>Rooms</p>
            </div>
          </a>

          <a href="/listings/category/iconic-cities" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='iconic-cities'?'active-filter':'' %>">
              <i class="fa-solid fa-mountain-city"></i><p>Iconic Cities</p>
            </div>
          </a>

          <a href="/listings/category/mountains" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='mountains'?'active-filter':'' %>">
              <i class="fa-solid fa-mountain"></i><p>Mountains</p>
            </div>
          </a>

          <a href="/listings/category/castles" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='castles'?'active-filter':'' %>">
              <i class="fa-brands fa-fort-awesome"></i><p>Castles</p>
            </div>
          </a>

          <a href="/listings/category/amazing-pools" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='amazing-pools'?'active-filter':'' %>">
              <i class="fa-solid fa-person-swimming"></i><p>Amazing Pools</p>
            </div>
          </a>

          <a href="/listings/category/camping" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='camping'?'active-filter':'' %>">
              <i class="fa-solid fa-campground"></i><p>Camping</p>
            </div>
          </a>

          <a href="/listings/category/farms" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='farms'?'active-filter':'' %>">
              <i class="fa-solid fa-cow"></i><p>Farms</p>
            </div>
          </a>

          <a href="/listings/category/arctic" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='arctic'?'active-filter':'' %>">
              <i class="fa-regular fa-snowflake"></i><p>Arctic</p>
            </div>
          </a>

          <a href="/listings/category/beachfront" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='beachfront'?'active-filter':'' %>">
              <i class="fa-solid fa-umbrella-beach"></i><p>Beachfront</p>
            </div>
          </a>

          <a href="/listings/category/luxury" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='luxury'?'active-filter':'' %>">
              <i class="fa-solid fa-gem"></i><p>Luxury</p>
            </div>
          </a>

          <a href="/listings/category/pet-friendly" class="filter-link">
            <div class="filter <%= typeof activeFilter!=='undefined'&&activeFilter==='pet-friendly'?'active-filter':'' %>">
              <i class="fa-solid fa-dog"></i><p>Pet Friendly</p>
            </div>
          </a>

        </div>
      </div>

      <button class="see-more-btn" id="seeMoreBtn" onclick="toggleFilters()">
        <i class="fa-solid fa-chevron-right" id="seeMoreIcon"></i>
        <span id="seeMoreText">See more</span>
      </button>

      <div class="tax-toggel">
        <div class="form-check-reverse form-switch"
          style="margin:0;padding:0;display:flex;align-items:center;gap:.45rem;">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault"
            style="margin:0;cursor:pointer;">
          <label class="form-check-label" for="switchCheckDefault">Total after taxes</label>
        </div>
      </div>

    </div>
  </div>

  <div class="container">
    <div id="listings-skeleton"></div>

    <div class="listings-grid">
      <% if (allListings.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon"><i class="fa-solid fa-search"></i></div>
          <h4>No listings found</h4>
          <p>Try different keywords or browse everything.</p>
          <a href="/listings" class="btn-dark-pill">View All Listings</a>
        </div>
      <% } else { %>
        <% for (let listing of allListings) { %>
          <div class="listing-item">
            <div class="listing-card" style="position:relative;">
              <div class="card-img-wrap">
                <a href="/listings/<%= listing._id %>">
                  <img src="<%= listing.image.url %>" alt="<%= listing.title %>" loading="lazy">
                </a>
                <% if (listing.category) { %>
                  <span class="card-badge"><%= listing.category %></span>
                <% } %>
                <button class="card-fav-btn" aria-label="Save to favourites"
                  data-id="<%= listing._id %>" onclick="toggleFav(this, event)">
                  <svg viewBox="0 0 24 24">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                  </svg>
                </button>
              </div>

              <a href="/listings/<%= listing._id %>">
                <div class="card-body">
                  <div class="card-top-row">
                    <h6 class="card-title"><%= listing.title %></h6>
                  </div>
                  <p class="card-location"><%= listing.location %>, <%= listing.country %></p>
                  <div class="price-without-tax">
                    <div class="price-line">
                      <span class="price-amount">&#8377;&nbsp;<%= (listing.price || 0).toLocaleString("en-IN") %></span>
                      <span class="price-label">/ night</span>
                    </div>
                  </div>
                  <div class="price-with-tax" style="display:none;">
                    <div class="price-line">
                      <span class="price-amount">&#8377;&nbsp;<%= ((listing.price || 0) * 1.18).toLocaleString("en-IN", { maximumFractionDigits: 0 }) %></span>
                      <span class="price-label">/ night incl. taxes</span>
                    </div>
                  </div>
                </div>
              </a>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>
  </div>

  <script>
    (function () {
      const skel = document.getElementById('listings-skeleton');
      const count = window.innerWidth <= 767 ? 4 : 8;
      for (let i = 0; i < count; i++) {
        skel.insertAdjacentHTML('beforeend',
          '<div class="skeleton-item">' +
          '<div class="skel-block skel-img"></div>' +
          '<div class="skel-block skel-title"></div>' +
          '<div class="skel-block skel-location"></div>' +
          '<div class="skel-block skel-price"></div>' +
          '</div>'
        );
      }
    })();

    window.addEventListener('load', function () {
      const skel = document.getElementById('listings-skeleton');
      const grid = document.querySelector('.listings-grid');
      skel.style.transition = 'opacity 0.3s ease';
      skel.style.opacity = '0';
      setTimeout(function () {
        skel.style.display = 'none';
        grid.style.display = 'grid';
        grid.style.opacity = '0';
        grid.style.transition = 'opacity 0.35s ease';
        requestAnimationFrame(function () { grid.style.opacity = '1'; });
      }, 300);
    });

    document.getElementById("switchCheckDefault").addEventListener("change", function () {
      document.querySelectorAll(".price-without-tax").forEach(el => el.style.display = this.checked ? "none" : "block");
      document.querySelectorAll(".price-with-tax").forEach(el => el.style.display = this.checked ? "block" : "none");
    });

    let showingAll = false;
    function toggleFilters() {
      if (window.innerWidth < 1037) return;
      showingAll = !showingAll;
      document.getElementById('filters').classList.toggle('show-extra', showingAll);
      document.getElementById('seeMoreIcon').className = showingAll ? 'fa-solid fa-chevron-left' : 'fa-solid fa-chevron-right';
      document.getElementById('seeMoreText').textContent = showingAll ? 'See less' : 'See more';
    }

    const FAV_KEY = 'wanderlust_favs';
    const getFavs = () => { try { return JSON.parse(localStorage.getItem(FAV_KEY)) || []; } catch { return []; } };
    const saveFavs = f => localStorage.setItem(FAV_KEY, JSON.stringify(f));

    function toggleFav(btn, e) {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.dataset.id;
      const favs = getFavs();
      const idx = favs.indexOf(id);
      const adding = idx === -1;
      adding ? favs.push(id) : favs.splice(idx, 1);
      saveFavs(favs);
      btn.classList.toggle('is-fav', adding);
      btn.classList.remove('pop');
      void btn.offsetWidth;
      btn.classList.add('pop');
      btn.addEventListener('animationend', () => btn.classList.remove('pop'), { once: true });
    }

    (function () {
      const favs = getFavs();
      document.querySelectorAll('.card-fav-btn').forEach(btn => {
        if (favs.includes(btn.dataset.id)) btn.classList.add('is-fav');
      });
    })();
  </script>