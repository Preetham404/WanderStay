<% layout("/layouts/boilerplate") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --ink: #1a1a1a;
    --ink-soft: #444;
    --ink-muted: #888;
    --surface: #f7f5f2;
    --white: #ffffff;
    --border: #e6e2db;
    --red: #e8334a;
    --red-dark: #c4293e;
    --red-glow: rgba(232,51,74,0.12);
    --tr: all 0.3s cubic-bezier(0.4,0,0.2,1);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--surface);
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: var(--ink);
  }

  .error-page {
    min-height: 82vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.25rem;
    position: relative;
    overflow: hidden;
  }

  .error-page::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(232,51,74,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .error-card {
    position: relative;
    z-index: 1;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 28px;
    padding: 3.5rem 3rem;
    max-width: 560px;
    width: 100%;
    text-align: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.05), 0 20px 60px rgba(0,0,0,0.07);
    animation: cardIn 0.55s cubic-bezier(0.4,0,0.2,1) forwards;
    opacity: 0;
    transform: translateY(24px);
  }

  @keyframes cardIn {
    to { opacity: 1; transform: translateY(0); }
  }

  .error-icon-wrap {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: #fff5f6;
    border: 2px solid rgba(232,51,74,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.75rem;
    animation: iconPulse 2.5s ease infinite;
  }

  @keyframes iconPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(232,51,74,0.12); }
    50%       { box-shadow: 0 0 0 12px rgba(232,51,74,0); }
  }

  .error-icon-wrap svg {
    width: 38px;
    height: 38px;
    color: var(--red);
  }

  .error-code {
    font-family: 'Nunito', sans-serif;
    font-size: clamp(5rem, 15vw, 7.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.06em;
    color: var(--ink);
    margin-bottom: 0.25rem;
    background: linear-gradient(135deg, var(--ink) 40%, var(--red));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .error-heading {
    font-family: 'Nunito', sans-serif;
    font-size: 1.45rem;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .error-message {
    font-size: 0.93rem;
    color: var(--ink-muted);
    line-height: 1.7;
    font-weight: 400;
    margin-bottom: 2rem;
    padding: 0 0.5rem;
  }

  .error-divider {
    width: 48px;
    height: 3px;
    background: var(--red);
    border-radius: 100px;
    margin: 0 auto 1.75rem;
    opacity: 0.5;
  }

  .btn-home {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    height: 48px;
    padding: 0 2rem;
    background: var(--ink);
    color: var(--white);
    border: none;
    border-radius: 100px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: var(--tr);
  }

  .btn-home::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--red);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .btn-home:hover::before { opacity: 1; }

  .btn-home:hover {
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(232,51,74,0.25);
  }

  .btn-home span,
  .btn-home i { position: relative; z-index: 1; }

  @media (max-width: 480px) {
    .error-card { padding: 2.5rem 1.5rem; }
    .btn-home { width: 100%; justify-content: center; }
  }
</style>

<div class="error-page">
  <div class="error-card">
    <div class="error-icon-wrap">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    </div>

    <div class="error-code"><%= statusCode || 500 %></div>

    <h2 class="error-heading">Something went wrong</h2>

    <div class="error-divider"></div>

    <p class="error-message"><%= message || "We couldn't complete your request. Please try again or head back home." %></p>

    <a href="/listings" class="btn-home">
      <i class="fa-solid fa-house"></i>
      <span>Back to Listings</span>
    </a>
  </div>
</div>