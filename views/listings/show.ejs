<% layout("layouts/boilerplate") %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --ink: #1a1a1a;
      --ink-soft: #444;
      --ink-muted: #888;
      --surface: #f7f5f2;
      --white: #ffffff;
      --border: #e6e2db;
      --red: #e8334a;
      --red-dark: #c4293e;
      --gold: #c9a84c;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.07);
      --shadow-md: 0 6px 24px rgba(0, 0, 0, 0.10);
      --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.12);
      --tr: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      --radius: 18px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--surface);
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--ink);
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .show-wrapper {
      max-width: 920px;
      margin: 0 auto;
      padding: 2.5rem 1.25rem 5rem;
    }


    .hero-wrap {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
    }

    .listing-hero {
      width: 100%;
      height: 500px;
      object-fit: cover;
      display: block;
      transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .hero-wrap:hover .listing-hero {
      transform: scale(1.03);
    }


    .hero-badge {
      position: absolute;
      bottom: 1.25rem;
      left: 1.25rem;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-radius: 100px;
      padding: 0.35rem 1rem;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink);
    }


    .listing-title-block {
      margin: 1.75rem 0 1.25rem;
    }

    .listing-title {
      font-family: 'Nunito', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 900;
      color: var(--ink);
      letter-spacing: -0.04em;
      line-height: 1.15;
      margin-bottom: 0.4rem;
    }

    .listing-location-line {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.88rem;
      color: var(--ink-muted);
      font-weight: 500;
    }

    .listing-location-line i {
      font-size: 0.8rem;
      color: var(--red);
    }

    .info-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.75rem 2rem;
      margin-bottom: 1.25rem;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
    }


    .owner-row {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding-bottom: 1.25rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .owner-avatar {
      width: 44px;
      height: 44px;
      background: var(--ink);
      color: var(--white);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 800;
      flex-shrink: 0;
      font-family: 'Nunito', sans-serif;
    }

    .owner-text {
      font-size: 0.88rem;
      color: var(--ink-soft);
    }

    .owner-text strong {
      color: var(--ink);
      font-weight: 700;
      font-size: 0.95rem;
    }


    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .detail-item {
      background: var(--surface);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      border: 1px solid var(--border);
    }

    .detail-label {
      font-size: 0.67rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--ink-muted);
      margin-bottom: 0.35rem;
    }

    .detail-value {
      font-size: 0.97rem;
      font-weight: 700;
      color: var(--ink);
    }

    .price-value {
      font-family: 'Nunito', sans-serif;
      font-size: 1.4rem;
      font-weight: 900;
      color: var(--ink);
      letter-spacing: -0.03em;
    }

    .price-value .per-night {
      font-size: 0.82rem;
      font-weight: 400;
      color: var(--ink-muted);
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: 0;
    }

    .description-box {
      grid-column: 1 / -1;
    }

    .description-text {
      font-size: 0.93rem;
      color: var(--ink-soft);
      line-height: 1.75;
      font-weight: 400;
    }


    .action-btns {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 1.5rem 0;
      flex-wrap: wrap;
    }


    .btn-edit {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      height: 44px;
      padding: 0 1.6rem;
      background: var(--ink);
      color: var(--white);
      border: 1.5px solid var(--ink);
      border-radius: 100px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      transition: var(--tr);
      text-decoration: none;
    }

    .btn-edit:hover {
      background: #333;
      border-color: #333;
      color: var(--white);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }


    .btn-delete {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      height: 44px;
      padding: 0 1.6rem;
      background: transparent;
      color: var(--red);
      border: 1.5px solid var(--red);
      border-radius: 100px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: var(--tr);
    }

    .btn-delete:hover {
      background: var(--red);
      color: var(--white);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(232, 51, 74, 0.2);
    }


    .section-divider {
      height: 1px;
      background: var(--border);
      margin: 1.75rem 0;
    }


    .review-section {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.75rem 2rem;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
      margin-bottom: 1.25rem;
    }

    .section-heading {
      font-family: 'Nunito', sans-serif;
      font-size: 1.35rem;
      font-weight: 900;
      color: var(--ink);
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    }


    .star-rating {
      display: flex;
      flex-direction: row-reverse;
      justify-content: flex-end;
      gap: 6px;
      border: none;
      padding: 0;
    }

    .star-rating input {
      display: none;
    }

    .star-rating label {
      font-size: 2.2rem;
      color: #ddd;
      cursor: pointer;
      transition: color 0.18s, transform 0.18s;
      line-height: 1;
    }

    .star-rating label:hover,
    .star-rating label:hover~label,
    .star-rating input:checked~label {
      color: var(--ink);
      transform: scale(1.1);
    }

    .no-rate {
      display: none;
    }


    .comment-box {
      width: 100%;
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 0.85rem 1rem;
      font-size: 0.9rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--ink);
      background: var(--surface);
      transition: var(--tr);
      resize: vertical;
      min-height: 110px;
      line-height: 1.6;
    }

    .comment-box::placeholder {
      color: var(--ink-muted);
      font-weight: 300;
    }

    .comment-box:hover {
      border-color: #c8c4bd;
      background: var(--white);
    }

    .comment-box:focus {
      border-color: var(--ink);
      background: var(--white);
      box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.06);
      outline: none;
    }


    .btn-submit-review {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      height: 44px;
      padding: 0 1.8rem;
      background: var(--ink);
      color: var(--white);
      border: none;
      border-radius: 100px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      cursor: pointer;
      transition: var(--tr);
      position: relative;
      overflow: hidden;
    }

    .btn-submit-review::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--gold), #a8873e);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .btn-submit-review:hover::before {
      opacity: 1;
    }

    .btn-submit-review:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
      color: var(--white);
    }

    .btn-submit-review span {
      position: relative;
      z-index: 1;
    }


    .reviews-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .review-count-badge {
      background: var(--surface);
      color: var(--ink-soft);
      padding: 0.3rem 0.9rem;
      border-radius: 100px;
      font-size: 0.78rem;
      font-weight: 700;
      border: 1.5px solid var(--border);
    }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.1rem;
    }

    .review-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.35rem;
      transition: var(--tr);
    }

    .review-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
      border-color: #d0ccc5;
    }

    .reviewer-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.85rem;
    }

    .reviewer-avatar {
      width: 40px;
      height: 40px;
      background: var(--ink);
      color: var(--white);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      font-weight: 800;
      flex-shrink: 0;
      font-family: 'Nunito', sans-serif;
    }

    .reviewer-name {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--ink);
      margin-bottom: 0.2rem;
    }

    .star-display {
      display: flex;
      gap: 2px;
    }

    .star-filled {
      color: var(--ink);
      font-size: 0.9rem;
    }

    .star-empty {
      color: #ddd;
      font-size: 0.9rem;
    }

    .review-comment {
      font-size: 0.88rem;
      color: var(--ink-soft);
      line-height: 1.65;
      padding-bottom: 0.85rem;
      margin-bottom: 0.85rem;
      border-bottom: 1px solid var(--border);
    }


    .btn-delete-review {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      height: 32px;
      padding: 0 1rem;
      background: transparent;
      color: var(--ink-muted);
      border: 1.5px solid var(--border);
      border-radius: 100px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.76rem;
      font-weight: 700;
      cursor: pointer;
      transition: var(--tr);
    }

    .btn-delete-review:hover {
      background: var(--red);
      color: white;
      border-color: var(--red);
    }


    .empty-reviews {
      background: var(--surface);
      border: 2px dashed var(--border);
      border-radius: 16px;
      padding: 3rem 2rem;
      text-align: center;
      color: var(--ink-muted);
      font-size: 0.9rem;
    }

    .empty-reviews i {
      font-size: 2rem;
      margin-bottom: 0.75rem;
      display: block;
      opacity: 0.4;
    }


    @media (max-width: 768px) {
      .listing-hero {
        height: 260px;
      }

      .detail-grid {
        grid-template-columns: 1fr;
      }

      .action-btns {
        flex-direction: column;
      }

      .btn-edit,
      .btn-delete {
        width: 100%;
        justify-content: center;
      }

      .info-card,
      .review-section {
        padding: 1.25rem;
      }

      .reviews-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="show-wrapper">


    <div class="hero-wrap">
      <img src="<%= listing.image.url %>" class="listing-hero" alt="<%= listing.title %>">
      <% if (listing.category) { %>
        <span class="hero-badge">
          <%= listing.category %>
        </span>
        <% } %>
    </div>


    <div class="listing-title-block">
      <h1 class="listing-title">
        <%= listing.title %>
      </h1>
      <div class="listing-location-line">
        <i class="fa-solid fa-location-dot"></i>
        <%= listing.location %>, <%= listing.country %>
      </div>
    </div>


    <div class="info-card">
      <div class="owner-row">
        <div class="owner-avatar">
          <%= listing.owner.username.charAt(0).toUpperCase() %>
        </div>
        <div class="owner-text">Hosted by <strong>
            <%= listing.owner.username %>
          </strong></div>
      </div>

      <div class="detail-grid">
        <div class="detail-item">
          <div class="detail-label">Price per night</div>
          <div class="price-value">
            &#8377;&nbsp;<% if (listing.price) { %>
              <%= Number(listing.price).toLocaleString("en-IN") %>
                <% } else { %>N/A<% } %>
                    <span class="per-night">/ night</span>
          </div>
        </div>

        <div class="detail-item">
          <div class="detail-label">Location</div>
          <div class="detail-value">
            <%= listing.location %>
          </div>
        </div>

        <div class="detail-item">
          <div class="detail-label">Country</div>
          <div class="detail-value">
            <%= listing.country %>
          </div>
        </div>

        <% if (listing.category) { %>
          <div class="detail-item">
            <div class="detail-label">Category</div>
            <div class="detail-value">
              <%= listing.category %>
            </div>
          </div>
          <% } %>

            <div class="detail-item description-box">
              <div class="detail-label">About this place</div>
              <p class="description-text">
                <%= listing.description %>
              </p>
            </div>
      </div>
    </div>


    <% if (currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
      <div class="action-btns">
        <a href="/listings/<%= listing._id %>/edit" class="btn-edit">
          <i class="fa-solid fa-pen-to-square"></i> Edit Listing
        </a>
        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" style="margin:0;">
          <button class="btn-delete" onclick="return confirm('Are you sure you want to delete this listing?')">
            <i class="fa-solid fa-trash"></i> Delete Listing
          </button>
        </form>
      </div>
      <% } %>

        <div class="section-divider"></div>

        <% if (currentUser) { %>
          <div class="review-section">
            <h4 class="section-heading">Leave a Review</h4>

            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

              <div class="mb-4">
                <label class="form-label"
                  style="font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--ink-soft);display:block;margin-bottom:.75rem;">Your
                  Rating</label>
                <fieldset class="star-rating">
                  <input type="radio" id="star5" name="review[rating]" value="5">
                  <label for="star5" title="Amazing">★</label>
                  <input type="radio" id="star4" name="review[rating]" value="4">
                  <label for="star4" title="Very good">★</label>
                  <input type="radio" id="star3" name="review[rating]" value="3">
                  <label for="star3" title="Average">★</label>
                  <input type="radio" id="star2" name="review[rating]" value="2">
                  <label for="star2" title="Not good">★</label>
                  <input type="radio" id="star1" name="review[rating]" value="1">
                  <label for="star1" title="Terrible">★</label>
                  <input type="radio" id="star0" name="review[rating]" value="0" checked class="no-rate">
                </fieldset>
              </div>

              <div class="mb-4">
                <label for="comment"
                  style="font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--ink-soft);display:block;margin-bottom:.5rem;">Your
                  Comment</label>
                <textarea id="comment" name="review[comment]" rows="4" class="comment-box"
                  placeholder="Share what made your stay memorable…" required></textarea>
                <div class="invalid-feedback">Please write a comment before submitting.</div>
              </div>

              <button type="submit" class="btn-submit-review">
                <span>Submit Review</span>
              </button>

            </form>
          </div>
          <% } %>

            <div class="section-divider"></div>


            <div>
              <div class="reviews-header">
                <h4 class="section-heading" style="margin-bottom:0;">All Reviews</h4>
                <% if (listing.reviews.length> 0) { %>
                  <span class="review-count-badge">
                    <%= listing.reviews.length %>
                      <%= listing.reviews.length===1 ? 'Review' : 'Reviews' %>
                  </span>
                  <% } %>
              </div>

              <% if (listing.reviews.length===0) { %>
                <div class="empty-reviews">
                  <i class="fa-regular fa-comment-dots"></i>
                  No reviews yet — be the first to share your experience!
                </div>
                <% } else { %>
                  <div class="reviews-grid">
                    <% for (let review of listing.reviews) { %>
                      <div class="review-card">
                        <div class="reviewer-row">
                          <div class="reviewer-avatar">
                            <%= review.author.username.charAt(0).toUpperCase() %>
                          </div>
                          <div>
                            <div class="reviewer-name">@<%= review.author.username %>
                            </div>
                            <div class="star-display">
                              <% for (let i=1; i <=5; i++) { %>
                                <span class="<%= i <= review.rating ? 'star-filled' : 'star-empty' %>">★</span>
                                <% } %>
                            </div>
                          </div>
                        </div>

                        <p class="review-comment">
                          <%= review.comment %>
                        </p>

                        <% if (currentUser && review.author && currentUser._id.equals(review.author._id)) { %>
                          <div style="text-align:right;">
                            <form method="POST"
                              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                              onsubmit="return confirm('Delete this review?');" style="margin:0;">
                              <button class="btn-delete-review">
                                <i class="fa-solid fa-trash"></i> Delete
                              </button>
                            </form>
                          </div>
                          <% } %>
                      </div>
                      <% } %>
                  </div>
                  <% } %>
            </div>

  </div>